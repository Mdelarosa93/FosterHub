{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@fosterhub/ui": ["packages/ui/src"],
      "@fosterhub/types": ["packages/types/src"],
      "@fosterhub/auth": ["packages/auth/src"]
    }
  }
}
