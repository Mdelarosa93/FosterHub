generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum IntakeStatus {
  NEW
  ASSIGNED
  CONVERTED
}

enum CaseStatus {
  INTAKE
  ACTIVE
  PENDING_PLACEMENT
  PLACED
  CLOSED
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DENIED
  COMPLETED
}

enum PermissionOverrideValue {
  ALLOW
  DENY
}

enum OrganizationType {
  STATE_AGENCY
  COUNTY_AGENCY
}

enum KnowledgeDocumentAccessScope {
  ORGANIZATION_ONLY
  INHERIT_TO_CHILDREN
}

enum KnowledgeDocumentStatus {
  DRAFT
  READY
  ARCHIVED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
  CUSTOM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

enum PaymentMethodProvider {
  STRIPE
  MANUAL
  INVOICE_ONLY
}

enum BillingInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum InvoiceLineItemType {
  BASE_PLAN
  SEAT
  COUNTY
  MODULE
  ADJUSTMENT
}

enum CountySubscriptionAllocationStatus {
  ACTIVE
  PENDING
  REMOVED
}

enum BillingModuleCategory {
  CORE
  ADD_ON
}

enum BillingAuditEventType {
  CONTACT_UPDATED
  PAYMENT_METHOD_UPDATED
  PLAN_CHANGED
  COUNTY_ALLOCATION_UPDATED
  MODULE_UPDATED
}

enum FosterApplicationStage {
  SUBMITTED
  MISSING_DOCUMENTS
  TRAINING_REQUIRED
  HOME_STUDY
  READY_FOR_APPROVAL
  APPROVED
  DENIED
}

enum VendorStatus {
  RECOMMENDED
  INVITED
  UNDER_REVIEW
  APPROVED
  DENIED
}

enum InvoiceStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  PAID
}

enum SurveyStatus {
  DRAFT
  SCHEDULED
  LIVE
  CLOSED
}

enum ApplicationReminderStatus {
  OPEN
  DISMISSED
}

enum FosterParentOnboardingStatus {
  NOT_STARTED
  INVITED
  ACCOUNT_ACTIVATED
  PROFILE_COMPLETED
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  type          OrganizationType @default(COUNTY_AGENCY)
  code          String?
  parentOrganizationId String?
  timezone      String         @default("America/New_York")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  parentOrganization Organization? @relation("OrganizationHierarchy", fields: [parentOrganizationId], references: [id])
  childOrganizations Organization[] @relation("OrganizationHierarchy")
  users         User[]
  teams         Team[]
  children      Child[]
  cases         Case[]
  intakeRecords IntakeRecord[]
  roleTemplates RoleTemplate[]
  fosterParentApplications FosterParentApplication[]
  travelApprovals TravelApproval[]
  vendors Vendor[]
  surveyCampaigns SurveyCampaign[]
  knowledgeDocumentSources KnowledgeDocumentSource[]
  knowledgeDocumentAuditEvents KnowledgeDocumentAuditEvent[]
  subscriptions OrganizationSubscription[]
  countySubscriptionAllocations SubscriptionCountyAllocation[] @relation("CountySubscriptionAllocationOrganization")
  billingAuditEvents BillingAuditEvent[]
}

model User {
  id                   String                   @id @default(cuid())
  organizationId       String
  firstName            String
  lastName             String
  email                String                   @unique
  phone                String?
  passwordHash         String?
  status               UserStatus               @default(INVITED)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  organization         Organization             @relation(fields: [organizationId], references: [id])
  roleAssignments      UserRoleAssignment[]
  permissionOverrides  UserPermissionOverride[]
  caseAssignments      CaseAssignment[]
  createdIntakeRecords IntakeRecord[]           @relation("CreatedIntakeRecords")
  assignedIntakeRecords IntakeRecord[]          @relation("AssignedIntakeRecords")
  decidedRequests      ServiceRequest[]         @relation("RequestDecider")
  uploadedDocuments    Document[]               @relation("UploadedDocuments")
  uploadedChecklistDocuments FosterApplicationChecklistDocument[] @relation("UploadedChecklistDocuments")
  fosterApplicationTimelineEvents FosterApplicationTimelineEvent[]
  assignedFosterApplications FosterParentApplication[] @relation("AssignedFosterApplications")
  fosterApplicationReminders FosterApplicationReminder[]
  createdKnowledgeDocumentSources KnowledgeDocumentSource[] @relation("KnowledgeDocumentCreatedBy")
  knowledgeDocumentAuditEvents KnowledgeDocumentAuditEvent[] @relation("KnowledgeDocumentAuditActor")
  seatAssignments SubscriptionSeatAssignment[]
  billingAuditEvents BillingAuditEvent[] @relation("BillingAuditActor")
}

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model RoleTemplate {
  id              String   @id @default(cuid())
  organizationId  String?
  key             String   @unique
  name            String
  description     String?
  isSystemDefault Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  assignments  UserRoleAssignment[]
  permissions  RoleTemplatePermission[]
}

model Permission {
  id                      String                   @id @default(cuid())
  key                     String                   @unique
  label                   String
  category                String
  description             String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  roleTemplatePermissions RoleTemplatePermission[]
  userOverrides           UserPermissionOverride[]
}

model RoleTemplatePermission {
  id             String       @id @default(cuid())
  roleTemplateId String
  permissionId   String

  roleTemplate   RoleTemplate @relation(fields: [roleTemplateId], references: [id])
  permission     Permission   @relation(fields: [permissionId], references: [id])

  @@unique([roleTemplateId, permissionId])
}

model UserRoleAssignment {
  id             String       @id @default(cuid())
  userId         String
  roleTemplateId String
  active         Boolean      @default(true)
  assignedAt     DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id])
  roleTemplate   RoleTemplate @relation(fields: [roleTemplateId], references: [id])

  @@unique([userId, roleTemplateId])
}

model UserPermissionOverride {
  id            String                  @id @default(cuid())
  userId        String
  permissionId  String
  overrideValue PermissionOverrideValue
  reason        String?
  createdAt     DateTime                @default(now())

  user          User                    @relation(fields: [userId], references: [id])
  permission    Permission              @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
}

model IntakeRecord {
  id                   String       @id @default(cuid())
  organizationId       String
  childFirstName       String
  childLastName        String
  status               IntakeStatus @default(NEW)
  notes                String?
  createdByUserId      String
  assignedWorkerUserId String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  organization         Organization @relation(fields: [organizationId], references: [id])
  createdBy            User         @relation("CreatedIntakeRecords", fields: [createdByUserId], references: [id])
  assignedWorker       User?        @relation("AssignedIntakeRecords", fields: [assignedWorkerUserId], references: [id])
}

model Child {
  id                  String        @id @default(cuid())
  organizationId      String
  firstName           String
  lastName            String
  preferredName       String?
  dateOfBirth         DateTime?
  caseReferenceNumber String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  organization        Organization  @relation(fields: [organizationId], references: [id])
  cases               Case[]
}

model Case {
  id                  String          @id @default(cuid())
  organizationId      String
  childId             String
  status              CaseStatus      @default(INTAKE)
  openedAt            DateTime        @default(now())
  closedAt            DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  organization        Organization    @relation(fields: [organizationId], references: [id])
  child               Child           @relation(fields: [childId], references: [id])
  assignments         CaseAssignment[]
  requests            ServiceRequest[]
  documents           Document[]
}

model CaseAssignment {
  id                  String        @id @default(cuid())
  caseId              String
  userId              String
  roleLabel           String
  createdAt           DateTime      @default(now())

  case                Case          @relation(fields: [caseId], references: [id])
  user                User          @relation(fields: [userId], references: [id])
}

model ServiceRequest {
  id                  String         @id @default(cuid())
  caseId              String
  title               String
  description         String?
  status              RequestStatus  @default(DRAFT)
  decisionNote        String?
  decidedAt           DateTime?
  decidedByUserId     String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  case                Case           @relation(fields: [caseId], references: [id])
  decidedBy           User?          @relation("RequestDecider", fields: [decidedByUserId], references: [id])
}

model Document {
  id               String    @id @default(cuid())
  caseId           String
  title            String
  fileName         String
  contentType      String?
  notes            String?
  uploadedByUserId String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  case             Case      @relation(fields: [caseId], references: [id])
  uploadedBy       User      @relation("UploadedDocuments", fields: [uploadedByUserId], references: [id])
}

model KnowledgeDocumentSource {
  id                String                       @id @default(cuid())
  organizationId    String
  title             String
  sourceType        String
  accessScope       KnowledgeDocumentAccessScope @default(ORGANIZATION_ONLY)
  status            KnowledgeDocumentStatus      @default(DRAFT)
  versionLabel      String?
  effectiveDate     DateTime?
  fileName          String?
  fileContentType   String?
  fileSizeBytes     Int?
  fileStoragePath   String?
  lastExtractedAt   DateTime?
  fileUrl           String?
  notes             String?
  createdByUserId   String
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  organization      Organization                 @relation(fields: [organizationId], references: [id])
  createdBy         User                         @relation("KnowledgeDocumentCreatedBy", fields: [createdByUserId], references: [id])
  sections          KnowledgeDocumentSection[]
  auditEvents       KnowledgeDocumentAuditEvent[]
  sectionSnapshots  KnowledgeDocumentSectionSnapshot[]

  @@index([organizationId, accessScope, status])
}

model KnowledgeDocumentSection {
  id                String                  @id @default(cuid())
  knowledgeDocumentSourceId String
  heading           String
  sectionKey        String?
  pageNumber        Int?
  sortOrder         Int                     @default(0)
  body              String
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  source            KnowledgeDocumentSource @relation(fields: [knowledgeDocumentSourceId], references: [id], onDelete: Cascade)

  @@index([knowledgeDocumentSourceId, sortOrder])
}

model KnowledgeDocumentAuditEvent {
  id                      String                   @id @default(cuid())
  knowledgeDocumentSourceId String?
  organizationId          String
  actorUserId             String?
  eventType               String
  summary                 String
  snapshotTitle           String
  snapshotVersionLabel    String?
  snapshotStatus          KnowledgeDocumentStatus?
  snapshotSectionCount    Int?
  createdAt               DateTime                 @default(now())

  source                  KnowledgeDocumentSource? @relation(fields: [knowledgeDocumentSourceId], references: [id], onDelete: SetNull)
  organization            Organization             @relation(fields: [organizationId], references: [id])
  actor                   User?                    @relation("KnowledgeDocumentAuditActor", fields: [actorUserId], references: [id])
  sectionSnapshots        KnowledgeDocumentSectionSnapshot[]

  @@index([knowledgeDocumentSourceId, createdAt])
  @@index([organizationId, createdAt])
}

model KnowledgeDocumentSectionSnapshot {
  id                      String                   @id @default(cuid())
  knowledgeDocumentSourceId String
  auditEventId            String?
  versionNumber           Int
  sectionCount            Int
  addedCount              Int                      @default(0)
  removedCount            Int                      @default(0)
  updatedCount            Int                      @default(0)
  snapshotJson            Json
  changedHeadingsJson     Json?
  createdAt               DateTime                 @default(now())

  source                  KnowledgeDocumentSource  @relation(fields: [knowledgeDocumentSourceId], references: [id], onDelete: Cascade)
  auditEvent              KnowledgeDocumentAuditEvent? @relation(fields: [auditEventId], references: [id], onDelete: SetNull)

  @@unique([knowledgeDocumentSourceId, versionNumber])
  @@index([knowledgeDocumentSourceId, createdAt])
}

model BillingPlan {
  id                         String                 @id @default(cuid())
  name                       String
  code                       String                 @unique
  description                String?
  billingInterval            BillingInterval        @default(MONTHLY)
  basePriceCents             Int                    @default(0)
  perSeatPriceCents          Int                    @default(0)
  countyIncludedCount        Int                    @default(0)
  additionalCountyPriceCents Int                    @default(0)
  active                     Boolean                @default(true)
  sortOrder                  Int                    @default(0)
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  planModules                BillingPlanModule[]
  subscriptions              OrganizationSubscription[]
}

model BillingModule {
  id             String                     @id @default(cuid())
  name           String
  code           String                     @unique
  description    String?
  category       BillingModuleCategory      @default(CORE)
  defaultIncluded Boolean                   @default(false)
  active         Boolean                    @default(true)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  planModules    BillingPlanModule[]
  subscriptionModules OrganizationSubscriptionModule[]
  seatAssignments SubscriptionSeatAssignment[]
}

model BillingPlanModule {
  id             String                     @id @default(cuid())
  billingPlanId   String
  billingModuleId String
  included       Boolean                    @default(true)
  seatLimit      Int?
  countyLimit    Int?

  billingPlan    BillingPlan                @relation(fields: [billingPlanId], references: [id], onDelete: Cascade)
  billingModule  BillingModule              @relation(fields: [billingModuleId], references: [id], onDelete: Cascade)

  @@unique([billingPlanId, billingModuleId])
}

model OrganizationSubscription {
  id                 String                    @id @default(cuid())
  organizationId     String
  billingPlanId      String
  status             SubscriptionStatus        @default(TRIALING)
  renewalDate        DateTime?
  startsAt           DateTime                  @default(now())
  endsAt             DateTime?
  seatCountPurchased Int                       @default(0)
  seatCountInUse     Int                       @default(0)
  countyCountCovered Int                       @default(0)
  billingContactName String?
  billingContactEmail String?
  billingContactPhone String?
  currency           String                    @default("USD")
  subtotalCents      Int                       @default(0)
  discountCents      Int                       @default(0)
  taxCents           Int                       @default(0)
  totalCents         Int                       @default(0)
  notes              String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  organization       Organization              @relation(fields: [organizationId], references: [id])
  billingPlan        BillingPlan               @relation(fields: [billingPlanId], references: [id])
  modules            OrganizationSubscriptionModule[]
  paymentMethods     PaymentMethod[]
  invoices           BillingInvoice[]
  countyAllocations  SubscriptionCountyAllocation[]
  seatAssignments    SubscriptionSeatAssignment[]
  auditEvents        BillingAuditEvent[]

  @@index([organizationId, status])
}

model OrganizationSubscriptionModule {
  id                         String                 @id @default(cuid())
  organizationSubscriptionId String
  billingModuleId            String
  enabled                    Boolean                @default(true)
  seatLimit                  Int?
  countyLimit                Int?
  priceOverrideCents         Int?

  organizationSubscription   OrganizationSubscription @relation(fields: [organizationSubscriptionId], references: [id], onDelete: Cascade)
  billingModule              BillingModule          @relation(fields: [billingModuleId], references: [id], onDelete: Cascade)

  @@unique([organizationSubscriptionId, billingModuleId])
}

model BillingAuditEvent {
  id                         String               @id @default(cuid())
  organizationSubscriptionId String
  organizationId             String
  actorUserId                String?
  eventType                  BillingAuditEventType
  summary                    String
  snapshotPlanName           String?
  snapshotStatus             SubscriptionStatus?
  snapshotTotalCents         Int?
  metadataJson               Json?
  createdAt                  DateTime             @default(now())

  organizationSubscription   OrganizationSubscription @relation(fields: [organizationSubscriptionId], references: [id], onDelete: Cascade)
  organization               Organization          @relation(fields: [organizationId], references: [id])
  actor                      User?                 @relation("BillingAuditActor", fields: [actorUserId], references: [id])

  @@index([organizationSubscriptionId, createdAt])
  @@index([organizationId, createdAt])
}

model PaymentMethod {
  id                         String                 @id @default(cuid())
  organizationSubscriptionId String
  provider                   PaymentMethodProvider  @default(STRIPE)
  providerPaymentMethodId    String?
  brand                      String?
  last4                      String?
  expMonth                   Int?
  expYear                    Int?
  isDefault                  Boolean                @default(false)
  billingName                String?
  billingEmail               String?
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  organizationSubscription   OrganizationSubscription @relation(fields: [organizationSubscriptionId], references: [id], onDelete: Cascade)

  @@index([organizationSubscriptionId, isDefault])
}

model BillingInvoice {
  id                         String                 @id @default(cuid())
  organizationSubscriptionId String
  invoiceNumber              String                 @unique
  providerInvoiceId          String?
  status                     BillingInvoiceStatus   @default(DRAFT)
  issuedAt                   DateTime               @default(now())
  dueAt                      DateTime?
  paidAt                     DateTime?
  subtotalCents              Int                    @default(0)
  taxCents                   Int                    @default(0)
  totalCents                 Int                    @default(0)
  currency                   String                 @default("USD")
  hostedInvoiceUrl           String?
  pdfUrl                     String?
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  organizationSubscription   OrganizationSubscription @relation(fields: [organizationSubscriptionId], references: [id], onDelete: Cascade)
  lineItems                  BillingInvoiceLineItem[]

  @@index([organizationSubscriptionId, status])
}

model BillingInvoiceLineItem {
  id               String            @id @default(cuid())
  billingInvoiceId  String
  description      String
  quantity         Int               @default(1)
  unitPriceCents   Int               @default(0)
  totalCents       Int               @default(0)
  lineType         InvoiceLineItemType @default(ADJUSTMENT)

  billingInvoice   BillingInvoice    @relation(fields: [billingInvoiceId], references: [id], onDelete: Cascade)
}

model SubscriptionCountyAllocation {
  id                         String                          @id @default(cuid())
  organizationSubscriptionId String
  countyOrganizationId       String
  status                     CountySubscriptionAllocationStatus @default(PENDING)
  seatLimit                  Int?
  seatInUse                  Int                             @default(0)
  startsAt                   DateTime                        @default(now())
  endsAt                     DateTime?
  notes                      String?
  createdAt                  DateTime                        @default(now())
  updatedAt                  DateTime                        @updatedAt

  organizationSubscription   OrganizationSubscription        @relation(fields: [organizationSubscriptionId], references: [id], onDelete: Cascade)
  countyOrganization         Organization                    @relation("CountySubscriptionAllocationOrganization", fields: [countyOrganizationId], references: [id], onDelete: Cascade)

  @@unique([organizationSubscriptionId, countyOrganizationId])
  @@index([countyOrganizationId, status])
}

model SubscriptionSeatAssignment {
  id                         String                    @id @default(cuid())
  organizationSubscriptionId String
  userId                     String
  countyOrganizationId       String?
  billingModuleId            String?
  active                     Boolean                   @default(true)
  assignedAt                 DateTime                  @default(now())
  revokedAt                  DateTime?

  organizationSubscription   OrganizationSubscription  @relation(fields: [organizationSubscriptionId], references: [id], onDelete: Cascade)
  user                       User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingModule              BillingModule?            @relation(fields: [billingModuleId], references: [id], onDelete: SetNull)

  @@index([organizationSubscriptionId, active])
  @@index([userId, active])
}

model FosterParentApplication {
  id                String                 @id @default(cuid())
  organizationId    String
  householdName     String
  primaryApplicant  String
  email             String?
  phone             String?
  stage             FosterApplicationStage @default(SUBMITTED)
  checklistProgress Int                    @default(0)
  assignedToUserId  String?
  convertedToUserId String?
  convertedAt       DateTime?
  onboardingStatus  FosterParentOnboardingStatus @default(NOT_STARTED)
  onboardingStatusUpdatedAt DateTime?
  submittedAt       DateTime               @default(now())
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  organization      Organization           @relation(fields: [organizationId], references: [id])
  assignedToUser    User?                  @relation("AssignedFosterApplications", fields: [assignedToUserId], references: [id])
  checklistItems    FosterApplicationChecklistItem[]
  timelineEvents    FosterApplicationTimelineEvent[]
  reminders         FosterApplicationReminder[]
}

model FosterApplicationReminder {
  id                         String                    @id @default(cuid())
  fosterParentApplicationId  String
  reminderType               String
  message                    String
  recipientUserId            String?
  status                     ApplicationReminderStatus @default(OPEN)
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt

  fosterParentApplication    FosterParentApplication   @relation(fields: [fosterParentApplicationId], references: [id], onDelete: Cascade)
  recipientUser              User?                     @relation(fields: [recipientUserId], references: [id])
}

model FosterApplicationTimelineEvent {
  id                         String                  @id @default(cuid())
  fosterParentApplicationId  String
  eventType                  String
  message                    String
  createdByUserId            String?
  createdAt                  DateTime                @default(now())

  fosterParentApplication    FosterParentApplication @relation(fields: [fosterParentApplicationId], references: [id], onDelete: Cascade)
  createdBy                  User?                   @relation(fields: [createdByUserId], references: [id])
}

model FosterApplicationChecklistItem {
  id                         String                  @id @default(cuid())
  fosterParentApplicationId  String
  label                      String
  requiresDocument           Boolean                 @default(false)
  requiredDocumentLabel      String?
  completed                  Boolean                 @default(false)
  sortOrder                  Int                     @default(0)
  completedAt                DateTime?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt

  fosterParentApplication    FosterParentApplication @relation(fields: [fosterParentApplicationId], references: [id], onDelete: Cascade)
  documents                  FosterApplicationChecklistDocument[]
}

model FosterApplicationChecklistDocument {
  id                             String                         @id @default(cuid())
  fosterApplicationChecklistItemId String
  title                          String
  fileName                       String
  contentType                    String?
  notes                          String?
  uploadedByUserId               String
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt

  checklistItem                  FosterApplicationChecklistItem @relation(fields: [fosterApplicationChecklistItemId], references: [id], onDelete: Cascade)
  uploadedBy                     User                           @relation("UploadedChecklistDocuments", fields: [uploadedByUserId], references: [id])
}

model TravelApproval {
  id                String        @id @default(cuid())
  organizationId    String
  caseId            String?
  submittedByUserId String?
  destination       String
  startDate         DateTime
  endDate           DateTime
  status            RequestStatus @default(SUBMITTED)
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization      Organization  @relation(fields: [organizationId], references: [id])
}

model Vendor {
  id                String         @id @default(cuid())
  organizationId    String
  name              String
  category          String
  city              String?
  status            VendorStatus   @default(RECOMMENDED)
  referredBy        String?
  portalEmail       String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  organization      Organization   @relation(fields: [organizationId], references: [id])
  invoices          VendorInvoice[]
}

model VendorInvoice {
  id                String        @id @default(cuid())
  vendorId          String
  invoiceNumber     String
  amountCents       Int
  status            InvoiceStatus @default(SUBMITTED)
  submittedAt       DateTime      @default(now())
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  vendor            Vendor        @relation(fields: [vendorId], references: [id])
}

model SurveyCampaign {
  id                String        @id @default(cuid())
  organizationId    String
  name              String
  audience          String
  cadence           String?
  baseline          Boolean       @default(false)
  status            SurveyStatus  @default(DRAFT)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization      Organization  @relation(fields: [organizationId], references: [id])
  responses         SurveyResponse[]
}

model SurveyResponse {
  id                String        @id @default(cuid())
  surveyCampaignId  String
  rating            Int?
  comment           String?
  submittedAt       DateTime      @default(now())

  surveyCampaign    SurveyCampaign @relation(fields: [surveyCampaignId], references: [id])
}
